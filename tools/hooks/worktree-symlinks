#!/usr/bin/env bash
# SPDX-FileCopyrightText: 2026 Koen van Greevenbroek
#
# SPDX-License-Identifier: CC-BY-4.0

# Symlink shared data directories from the main worktree into git worktrees,
# so that expensive-to-recreate data is reused without re-downloading or
# recomputing. Runs as a post-checkout hook via prek/pre-commit.
#
# Only gitignored subdirectories are symlinked. Git-tracked subdirectories
# (data/curated/, data/bundled/) intentionally stay as per-worktree
# checkouts so that branch-specific edits to tracked CSVs (e.g. adding a
# new model crop) are visible to git in the worktree where the edit is
# made. Symlinking the entire data/ directory was the historical pattern
# but caused split-checkout problems: edits landed in the main worktree's
# files instead of the active branch's working tree.

set -euo pipefail

# Only act on branch checkouts (flag=1), not file checkouts.
[[ "${3:-1}" == "1" ]] || exit 0

GIT_DIR=$(git rev-parse --git-dir)
COMMON_DIR=$(git rev-parse --git-common-dir)

# Only run inside worktrees, not in the main working tree.
[[ "$(realpath "$GIT_DIR")" != "$(realpath "$COMMON_DIR")" ]] || exit 0

MAIN_WORKTREE=$(cd "$COMMON_DIR/.." && pwd)
WORKTREE_ROOT=$(git rev-parse --show-toplevel)

# Gitignored directories that are heavy or slow to recreate. Symlinked
# from the main worktree so worktrees share them instead of downloading
# / recomputing per-branch.
SHARED_DIRS=(
    data/downloads
    data/manually_downloaded
    processing
)

# Gitignored files to symlink.
SHARED_FILES=(
    config/secrets.yaml
)

for dir in "${SHARED_DIRS[@]}"; do
    target="$MAIN_WORKTREE/$dir"
    link="$WORKTREE_ROOT/$dir"
    if [[ -d "$target" ]] && [[ ! -e "$link" ]]; then
        mkdir -p "$(dirname "$link")"
        ln -s "$target" "$link"
        echo "Worktree: symlinked $dir"
    fi
done

for file in "${SHARED_FILES[@]}"; do
    target="$MAIN_WORKTREE/$file"
    link="$WORKTREE_ROOT/$file"
    if [[ -f "$target" ]] && [[ ! -e "$link" ]]; then
        mkdir -p "$(dirname "$link")"
        ln -s "$target" "$link"
        echo "Worktree: symlinked $file"
    fi
done
