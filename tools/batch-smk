"""Submit solve jobs as a SLURM array with failure tolerance.

Each array element runs a batch of scenarios via Snakemake with --keep-going,
so a failed solve does not affect siblings. Uses the Snakemake Python API to
determine which scenarios actually need solving (respects code/input/param
changes, not just missing outputs).
"""

import argparse
from datetime import datetime
import math
import os
from pathlib import Path
import re
import subprocess
import sys

from snakemake.api import SnakemakeApi
from snakemake.settings.types import (
    ConfigSettings,
    DAGSettings,
    OutputSettings,
    ResourceSettings,
)
import yaml

PROJECT_ROOT = Path(__file__).resolve().parent.parent
SNAKEFILE = PROJECT_ROOT / "workflow" / "Snakefile"
CONFIG_DEFAULT = PROJECT_ROOT / "config" / "default.yaml"

SOLVE_OUTPUT_RE = re.compile(r"results/.+/solved/model_scen-(.+)\.nc$")
# When inline_analysis is enabled the fused rule targets analysis parquets
# instead of solved .nc files.  We use a single representative parquet to
# detect pending scenarios.
INLINE_OUTPUT_RE = re.compile(
    r"results/.+/analysis/scen-(.+)/objective_breakdown\.parquet$"
)

# Overhead for the Snakemake process + Python interpreter inside each SLURM
# array element, on top of the memory allocated for the solves themselves.
OVERHEAD_MB = 2000

# Import shared utilities from the workflow package.
sys.path.insert(0, str(PROJECT_ROOT / "workflow" / "scripts"))
from snakemake_utils import _recursive_update, load_scenarios  # noqa: E402


def load_merged_config(*configfiles: Path) -> dict:
    """Load and merge YAML config files (later files override earlier ones)."""
    merged = {}
    for path in configfiles:
        with open(path) as f:
            data = yaml.safe_load(f) or {}
        _recursive_update(merged, data)
    return merged


def get_pending_scenarios(
    configfiles: list[Path],
    name: str,
    all_scenarios: list[str],
    inline_analysis: bool,
    force_incomplete: bool = False,
) -> list[str]:
    """Find which solve jobs need running via the Snakemake Python API.

    Builds the full DAG in dryrun mode targeting all solve outputs, executes a
    dryrun, then filters ``updated_files`` for solve outputs. This catches
    missing outputs as well as code/input/param changes.

    When *inline_analysis* is true, targets are analysis parquets (produced by
    ``solve_and_analyze_model``) instead of solved ``.nc`` files.

    Note: we cannot use ``allowed_rules`` in DAGSettings here because that
    prevents Snakemake from resolving upstream dependencies during DAG
    construction (it raises MissingInputException for inputs that come from
    other rules). Instead we build the full DAG and filter the output list.
    The ``--allowed-rules`` flag in the generated sbatch script serves a
    different purpose: it prevents execution of upstream rules at runtime
    (builds should already be complete by then).
    """
    if inline_analysis:
        targets = [
            f"results/{name}/analysis/scen-{s}/objective_breakdown.parquet"
            for s in all_scenarios
        ]
        output_re = INLINE_OUTPUT_RE
    else:
        targets = [f"results/{name}/solved/model_scen-{s}.nc" for s in all_scenarios]
        output_re = SOLVE_OUTPUT_RE

    updated: list[str] = []
    # Suppress all dryrun output (Snakemake's logger writes directly to
    # stderr/stdout, so we redirect at the file descriptor level).
    devnull_fd = os.open(os.devnull, os.O_WRONLY)
    saved_stdout = os.dup(1)
    saved_stderr = os.dup(2)
    os.dup2(devnull_fd, 1)
    os.dup2(devnull_fd, 2)
    try:
        with SnakemakeApi(OutputSettings(dryrun=True)) as api:
            wf = api.workflow(
                resource_settings=ResourceSettings(cores=1),
                config_settings=ConfigSettings(configfiles=configfiles),
                snakefile=SNAKEFILE,
                workdir=PROJECT_ROOT,
            )
            dag = wf.dag(
                dag_settings=DAGSettings(
                    targets=frozenset(targets),
                    force_incomplete=force_incomplete,
                )
            )
            dag.execute_workflow(executor="dryrun", updated_files=updated)
    finally:
        os.dup2(saved_stdout, 1)
        os.dup2(saved_stderr, 2)
        os.close(devnull_fd)
        os.close(saved_stdout)
        os.close(saved_stderr)

    pending = []
    for f in updated:
        m = output_re.search(f)
        if m:
            pending.append(m.group(1))
    return sorted(pending)


def compute_resources(config: dict, parallel: int, batch_size: int) -> dict:
    """Compute default SLURM resources from config."""
    solving = config["solving"]
    base_mem_mb = solving["mem_mb"]
    base_runtime = solving["runtime"]
    time_limit = solving["time_limit"]
    threads = int(solving["threads"])
    max_retries = 2  # matches solve_model retries: 2

    mem_mb = parallel * base_mem_mb + OVERHEAD_MB

    # Time: worst-case assuming every solve retries to max
    max_solve_time = base_runtime * (5**max_retries)
    if time_limit is not None:
        max_solve_time = min(max_solve_time, time_limit + 10)
    time_minutes = math.ceil(batch_size / parallel) * max_solve_time + 15

    return {
        "mem_mb": mem_mb,
        "time_minutes": time_minutes,
        "cpus": parallel * threads,
    }


def format_time(minutes: int) -> str:
    """Format minutes as HH:MM:SS for SLURM."""
    h, m = divmod(minutes, 60)
    return f"{h}:{m:02d}:00"


def parse_time(time_str: str) -> int:
    """Parse HH:MM:SS or H:MM:SS to minutes (seconds ignored)."""
    parts = time_str.split(":")
    if len(parts) == 3 or len(parts) == 2:
        return int(parts[0]) * 60 + int(parts[1])
    raise ValueError(f"Cannot parse time: {time_str}")


def parse_mem(mem_str: str) -> int:
    """Parse memory string like '40G' or '40000M' to MB."""
    mem_str = mem_str.strip().upper()
    if mem_str.endswith("G"):
        return int(float(mem_str[:-1]) * 1000)
    elif mem_str.endswith("M"):
        return int(mem_str[:-1])
    elif mem_str.endswith("T"):
        return int(float(mem_str[:-1]) * 1000000)
    return int(mem_str)


def main():
    parser = argparse.ArgumentParser(
        description="Submit solve jobs as a SLURM array with failure tolerance. "
        "Unrecognized arguments are forwarded to Snakemake (e.g. --rerun-incomplete).",
    )
    parser.add_argument(
        "--configfile",
        required=True,
        help="Path to the config YAML file",
    )
    parser.add_argument(
        "--batch-size",
        type=int,
        default=50,
        help="Number of scenarios per SLURM array element (default: 50)",
    )
    parser.add_argument(
        "-j",
        "--parallel",
        type=int,
        default=4,
        help="Concurrent solves per array element (default: 4)",
    )
    parser.add_argument(
        "--time",
        help="SLURM time limit (HH:MM:SS), overrides computed default",
    )
    parser.add_argument(
        "--mem",
        help="SLURM memory (e.g., 40G), overrides computed default",
    )
    parser.add_argument(
        "-e",
        "--environment",
        help="Pixi environment to use (e.g., gurobi), passed to tools/smk -e",
    )
    parser.add_argument("--partition", help="SLURM partition")
    parser.add_argument("--account", help="SLURM account")
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Print plan and generated script without submitting",
    )
    parser.add_argument(
        "--sbatch-args",
        default="",
        help="Extra sbatch arguments (e.g., '--qos=normal --mail-type=END')",
    )
    args, extra_smk_args = parser.parse_known_args()

    configfile = Path(args.configfile).resolve()
    configfiles = [CONFIG_DEFAULT, configfile]

    config = load_merged_config(*configfiles)
    name = config["name"]
    inline_analysis = config["solving"]["inline_analysis"]

    # Get all scenarios
    print(f"Loading scenarios for config '{name}'...")
    all_scenarios = list(load_scenarios(config))
    print(f"  Total scenarios: {len(all_scenarios)}")
    if inline_analysis:
        print("  Mode: inline_analysis (solve_and_analyze_model)")

    # Determine which scenarios need solving
    force_incomplete = "--rerun-incomplete" in extra_smk_args
    print("Building DAG to find pending solves...")
    pending = get_pending_scenarios(
        configfiles, name, all_scenarios, inline_analysis,
        force_incomplete=force_incomplete,
    )
    print(f"  Pending solves: {len(pending)}")

    if not pending:
        print("All scenarios are up to date. Nothing to submit.")
        return

    # Compute resources
    resources = compute_resources(config, args.parallel, args.batch_size)
    mem_mb = parse_mem(args.mem) if args.mem else resources["mem_mb"]
    time_minutes = parse_time(args.time) if args.time else resources["time_minutes"]
    cpus = resources["cpus"]

    # Element-level mem_mb for Snakemake --resources scheduling
    element_mem_mb = mem_mb - OVERHEAD_MB

    # Batch layout
    n_batches = math.ceil(len(pending) / args.batch_size)

    print("\nBatch layout:")
    print(f"  Scenarios to solve: {len(pending)}")
    print(f"  Batch size: {args.batch_size}")
    print(f"  Array elements: {n_batches}")
    print(f"  Parallel solves per element: {args.parallel}")
    print(f"  CPUs per element: {cpus}")
    print(f"  Memory per element: {mem_mb} MB ({mem_mb / 1000:.1f} GB)")
    print(f"  Time per element: {format_time(time_minutes)}")

    # Create .batch directory
    batch_dir = PROJECT_ROOT / ".batch"
    logs_dir = batch_dir / "logs"
    logs_dir.mkdir(parents=True, exist_ok=True)

    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")

    # Write manifest (one scenario name per line)
    manifest_path = batch_dir / f"manifest_{name}_{timestamp}.txt"
    manifest_path.write_text("\n".join(pending) + "\n")
    print(f"\n  Manifest: {manifest_path}")

    # Build sbatch directives
    sbatch_lines = [
        f"#SBATCH --array=0-{n_batches - 1}",
        f"#SBATCH --time={format_time(time_minutes)}",
        f"#SBATCH --mem={mem_mb}M",
        f"#SBATCH --cpus-per-task={cpus}",
        f"#SBATCH --job-name=solve_{name}",
        f"#SBATCH --output={logs_dir}/solve_%A_%a.out",
        f"#SBATCH --error={logs_dir}/solve_%A_%a.err",
    ]
    if args.partition:
        sbatch_lines.append(f"#SBATCH --partition={args.partition}")
    if args.account:
        sbatch_lines.append(f"#SBATCH --account={args.account}")
    if args.sbatch_args:
        for extra in args.sbatch_args.split():
            sbatch_lines.append(f"#SBATCH {extra}")

    sbatch_directives = "\n".join(sbatch_lines)
    extra_smk_str = (" ".join(extra_smk_args) + " ") if extra_smk_args else ""
    env_flag = f"-e {args.environment} " if args.environment else ""

    if inline_analysis:
        # Fused rule: target a representative analysis parquet per scenario.
        allowed_rule = "solve_and_analyze_model"
        target_line = 'TARGETS+=("results/${NAME}/analysis/scen-${s}/objective_breakdown.parquet")'
    else:
        allowed_rule = "solve_model"
        target_line = 'TARGETS+=("results/${NAME}/solved/model_scen-${s}.nc")'

    script_content = f"""\
#!/bin/bash
{sbatch_directives}

set -euo pipefail

MANIFEST="{manifest_path}"
BATCH_SIZE={args.batch_size}
PARALLEL={args.parallel}
CORES={cpus}
CONFIG="{configfile}"
NAME="{name}"
ELEMENT_MEM_MB={element_mem_mb}

# Read this element's scenarios from the manifest
BATCH_START=$((SLURM_ARRAY_TASK_ID * BATCH_SIZE + 1))
BATCH_END=$((BATCH_START + BATCH_SIZE - 1))
SCENARIOS=$(sed -n "${{BATCH_START}},${{BATCH_END}}p" "$MANIFEST")

if [ -z "$SCENARIOS" ]; then
    echo "No scenarios for array task $SLURM_ARRAY_TASK_ID"
    exit 0
fi

# Build target list
TARGETS=()
for s in $SCENARIOS; do
    {target_line}
done

echo "Array task $SLURM_ARRAY_TASK_ID: solving ${{#TARGETS[@]}} scenarios"

cd "{PROJECT_ROOT}"

# --keep-going: failures don't kill siblings
# --nolock: safe because array elements target disjoint scenarios
# --allowed-rules: only run {allowed_rule}, never upstream rules
tools/smk {env_flag}-j${{CORES}} --keep-going --nolock \\
    --allowed-rules {allowed_rule} \\
    --configfile "$CONFIG" \\
    --resources mem_mb=${{ELEMENT_MEM_MB}} \\
    {extra_smk_str}-- "${{TARGETS[@]}}"
"""

    script_path = batch_dir / f"batch_solve_{name}_{timestamp}.sh"
    script_path.write_text(script_content)
    script_path.chmod(0o755)
    print(f"  Script: {script_path}")

    if args.dry_run:
        print("\n--- Generated sbatch script ---")
        print(script_content)
        print("--- Dry run: not submitting ---")
        return

    # Submit
    result = subprocess.run(
        ["sbatch", str(script_path)],
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        print(f"sbatch failed:\n{result.stderr}", file=sys.stderr)
        sys.exit(1)

    print(f"\n{result.stdout.strip()}")
    print(f"Monitor with: squeue -u $USER -n solve_{name}")


if __name__ == "__main__":
    main()
