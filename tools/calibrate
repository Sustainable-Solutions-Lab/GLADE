# Orchestrator for the calibrations that feed the default workflow.
#
# Dependency order (upstream data changed → rerun in this order):
#   1. feed        → data/curated/calibration/{grassland_yield,fodder_conversion,exogenous_forage,exogenous_protein}.csv
#   2. food_waste  → data/curated/calibration/food_waste.yaml
#   3. food_demand → data/curated/calibration/food_demand.csv
#   4. cost        → data/curated/calibration/{crop_cost,grassland_cost,animal_cost}.csv
#   5. stability   → data/curated/calibration/prod_stability_l1.yaml
#
# Usage:
#   tools/calibrate                # run all in order
#   tools/calibrate feed           # one step (forage + protein feed slack)
#   tools/calibrate food_waste
#   tools/calibrate food_demand
#   tools/calibrate cost
#   tools/calibrate stability
#   tools/calibrate --check        # report which calibrations are stale (no execution)
#
# All steps invoke ``tools/smk`` under the hood; any extra flags after the
# subcommand are passed through.
#
# The pixi env defaults to ``gurobi`` since all calibration configs use the
# Gurobi solver. Override with ``CALIBRATE_PIXI_ENV=<name>`` or by passing
# ``-e <name>`` explicitly.

set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
cd "$PROJECT_ROOT"

FEED_TARGETS=(
  data/curated/calibration/grassland_yield.csv
  data/curated/calibration/fodder_conversion.csv
  data/curated/calibration/exogenous_forage.csv
  data/curated/calibration/exogenous_protein.csv
)
FOOD_WASTE_TARGETS=(
  data/curated/calibration/food_waste.yaml
)
FOOD_DEMAND_TARGETS=(
  data/curated/calibration/food_demand.csv
)
COST_TARGETS=(
  data/curated/calibration/crop_cost.csv
  data/curated/calibration/grassland_cost.csv
  data/curated/calibration/animal_cost.csv
)
STABILITY_TARGETS=(
  data/curated/calibration/prod_stability_l1.yaml
)

# All three calibration configs use gurobi; default the pixi env accordingly.
# Caller can override by setting CALIBRATE_PIXI_ENV= (empty) or a different env.
DEFAULT_PIXI_ENV="${CALIBRATE_PIXI_ENV-gurobi}"

# Split argv into (targets, passthrough) at a `--` separator.
#   split_args <target1> <target2> ... -- <passthrough...>
# On return, $TARGETS_ARR and $PASSTHROUGH_ARR global arrays hold each side.
split_args() {
  TARGETS_ARR=()
  PASSTHROUGH_ARR=()
  local seen_sep=0
  for arg in "$@"; do
    if [[ "$arg" == "--" && $seen_sep -eq 0 ]]; then
      seen_sep=1
      continue
    fi
    if [[ $seen_sep -eq 0 ]]; then
      TARGETS_ARR+=("$arg")
    else
      PASSTHROUGH_ARR+=("$arg")
    fi
  done
}

# Prepend `-e <env>` to PASSTHROUGH_ARR unless the user already passed one, or
# DEFAULT_PIXI_ENV is empty. Modifies PASSTHROUGH_ARR in place.
inject_env() {
  [[ -z "$DEFAULT_PIXI_ENV" ]] && return 0
  local arg
  for arg in "${PASSTHROUGH_ARR[@]}"; do
    case "$arg" in
      -e|--env) return 0 ;;
    esac
  done
  PASSTHROUGH_ARR=(-e "$DEFAULT_PIXI_ENV" "${PASSTHROUGH_ARR[@]}")
}

run_step() {
  local label="$1" configfile="$2"
  shift 2
  split_args "$@"
  inject_env
  echo "[calibrate] $label -- tools/smk --configfile $configfile ${PASSTHROUGH_ARR[*]} -- ${TARGETS_ARR[*]}"
  tools/smk --configfile "$configfile" "${PASSTHROUGH_ARR[@]}" -- "${TARGETS_ARR[@]}"
}

check_step() {
  local label="$1" configfile="$2"
  shift 2
  split_args "$@"
  inject_env
  local out
  if ! out=$(tools/smk --configfile "$configfile" "${PASSTHROUGH_ARR[@]}" --dry-run --quiet -- "${TARGETS_ARR[@]}" 2>&1); then
    printf '  [error]      %-10s (dry-run failed; see output below)\n' "$label"
    printf '%s\n' "$out" | sed 's/^/    /'
    return 2
  fi
  # Snakemake prints "Nothing to be done" when everything is up-to-date.
  if echo "$out" | grep -q "Nothing to be done"; then
    printf '  [up-to-date] %-10s\n' "$label"
  else
    printf '  [STALE]      %-10s (run: tools/calibrate %s)\n' "$label" "$label"
  fi
}

cmd="${1:-all}"
shift || true

case "$cmd" in
  -h|--help|help)
    sed -n '7,22p' "$0"
    exit 0
    ;;
  --check|check)
    echo "[calibrate] Checking staleness (no execution) ..."
    rc=0
    check_step feed        config/calibration/feed.yaml        "${FEED_TARGETS[@]}"        -- "$@" || rc=$?
    check_step food_waste  config/calibration/food_waste.yaml  "${FOOD_WASTE_TARGETS[@]}"  -- "$@" || rc=$?
    check_step food_demand config/calibration/food_demand.yaml "${FOOD_DEMAND_TARGETS[@]}" -- "$@" || rc=$?
    check_step cost        config/calibration/cost.yaml        "${COST_TARGETS[@]}"        -- "$@" || rc=$?
    check_step stability   config/calibration/stability.yaml   "${STABILITY_TARGETS[@]}"   -- "$@" || rc=$?
    exit "$rc"
    ;;
  all)
    run_step feed        config/calibration/feed.yaml        "${FEED_TARGETS[@]}"        -- "$@"
    run_step food_waste  config/calibration/food_waste.yaml  "${FOOD_WASTE_TARGETS[@]}"  -- "$@"
    run_step food_demand config/calibration/food_demand.yaml "${FOOD_DEMAND_TARGETS[@]}" -- "$@"
    run_step cost        config/calibration/cost.yaml        "${COST_TARGETS[@]}"        -- "$@"
    run_step stability   config/calibration/stability.yaml   "${STABILITY_TARGETS[@]}"   -- "$@"
    ;;
  feed)
    run_step feed config/calibration/feed.yaml "${FEED_TARGETS[@]}" -- "$@"
    ;;
  food_waste)
    run_step food_waste config/calibration/food_waste.yaml "${FOOD_WASTE_TARGETS[@]}" -- "$@"
    ;;
  food_demand)
    run_step food_demand config/calibration/food_demand.yaml "${FOOD_DEMAND_TARGETS[@]}" -- "$@"
    ;;
  cost)
    run_step cost config/calibration/cost.yaml "${COST_TARGETS[@]}" -- "$@"
    ;;
  stability)
    run_step stability config/calibration/stability.yaml "${STABILITY_TARGETS[@]}" -- "$@"
    ;;
  *)
    echo "[calibrate] Unknown subcommand: $cmd" >&2
    echo "Usage: tools/calibrate [all|feed|food_waste|food_demand|cost|stability|--check]" >&2
    exit 2
    ;;
esac
