.snakemake
results
processing
# Notebooks (exploratory, not tracked by default)
notebooks/*
!notebooks/sensitivity_utils.py
!notebooks/*_sensitivity.ipynb
logs
benchmarks
data/downloads/*
# Also ignore data/downloads itself when it is a worktree symlink to
# the main worktree's data/downloads directory.
data/downloads
**/__pycache__
*.egg-info/
gurobi.log
/.pixi/
vendor
/.codex/
/.claude/
/.serena/
/.batch/
/.cache/
/.tmp/
notes/
notes.org
docs/_static/figures/*

# Secrets (never commit credentials)
config/secrets.yaml

# Local-only config overrides (e.g. cluster connection details)
config/*.local.yaml
/tools/snakemake-logger-plugin-compact/build/

# Stray uv lock file (project uses pixi, not uv).
uv.lock

# Project-private workspace (per-investigation configs, scripts, scratch data
# and notebooks that should not pollute the main repo). Not version-controlled.
/tools/private/
