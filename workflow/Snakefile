import os
from pathlib import Path

from snakemake.utils import min_version

from validation import load_secrets_with_env_fallback, validate

min_version("9.0")

os.makedirs("data/downloads", exist_ok=True)


configfile: "config/default.yaml"


# Load and merge secrets from file or environment variables
secrets = load_secrets_with_env_fallback(Path.cwd())
config.setdefault("credentials", {}).update(secrets)


validate(config, project_root=Path.cwd())


def _resolve_path_root(raw_path: str, key: str) -> str:
    """Resolve environment variables and user-home markers in a path root."""
    resolved = os.path.expanduser(os.path.expandvars(raw_path))
    if "$" in resolved:
        raise ValueError(
            f"Unresolved environment variable in config.paths.{key}: '{raw_path}'"
        )
    if resolved != "/":
        resolved = resolved.rstrip("/")
    return resolved


PATH_ROOTS = {
    "results": _resolve_path_root(config["paths"]["results_root"], "results_root"),
    "processing": _resolve_path_root(
        config["paths"]["processing_root"], "processing_root"
    ),
    "logs": _resolve_path_root(config["paths"]["logs_root"], "logs_root"),
    "benchmarks": _resolve_path_root(
        config["paths"]["benchmarks_root"], "benchmarks_root"
    ),
}


pathvars:
    results=PATH_ROOTS["results"],
    processing=PATH_ROOTS["processing"],
    logs=PATH_ROOTS["logs"],
    benchmarks=PATH_ROOTS["benchmarks"],


